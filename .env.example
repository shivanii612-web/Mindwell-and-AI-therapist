# MindWell AI Therapy Platform — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# ── Frontend (VITE_ prefix required for Vite to expose to browser) ──────────
# Razorpay publishable key — safe to put in frontend (not the secret)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# Set to true only when Daily.co billing is configured
VITE_ENABLE_DAILY=false

# ── Backend — place these in server/.env (not this file) ────────────────────
# MongoDB Atlas connection string
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mindwell

# JWT secrets — use long random strings
# JWT_SECRET=your_long_random_jwt_secret
# JWT_REFRESH_SECRET=your_long_random_refresh_secret

# Google Gemini AI
# GEMINI_API_KEY=your_gemini_api_key

# Gmail for transactional emails
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password
# ADMIN_EMAIL=admin@yourdomain.com

# Razorpay (test mode)
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# Redis (optional)
# REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379

# Daily.co (optional — production video)
# DAILY_API_KEY=your_daily_api_key
# DAILY_DOMAIN=yoursubdomain.daily.co
