# ──────────────────────────────────────────────────────────────────
# MindWell Docker Environment Template
# Copy this to .env (in the project root) before running:
#   docker compose up --build
#
# Docker Compose reads from the ROOT .env file automatically.
# Never commit the real .env — it contains secrets.
# ──────────────────────────────────────────────────────────────────

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mindwell

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Email (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
ADMIN_EMAIL=admin@yourdomain.com

# Razorpay (test mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Daily.co (optional — video consultation)
DAILY_API_KEY=your_daily_api_key_here
DAILY_DOMAIN=yoursubdomain.daily.co

# Frontend build-time variables (embedded into JS bundle — no secrets here)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
VITE_ENABLE_DAILY=false
